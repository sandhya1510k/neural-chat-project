{
  "info": {
    "name": "NeuralChat API",
    "description": "Complete API collection for the NeuralChat AI Chatbot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/../api/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) pm.collectionVariables.set('token', json.token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ada Lovelace\",\n  \"email\": \"ada@test.com\",\n  \"password\": \"test1234\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) pm.collectionVariables.set('token', json.token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ada@test.com\",\n  \"password\": \"test1234\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "Create Conversation",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.conversation?._id) pm.collectionVariables.set('convId', json.conversation._id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chat/conversations",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Chat\"\n}"
            }
          }
        },
        {
          "name": "List Conversations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chat/conversations",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chat/conversations/{{convId}}/messages",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Conversation",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/chat/conversations/{{convId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
